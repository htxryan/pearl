{
  "name": "pearl-bdui",
  "version": "0.6.0",
  "description": "Pearl: A web UI for the Beads issue tracker",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "pearl-bdui": "bin/pearl.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "bin",
    "frontend-dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:dist": "node scripts/build-dist.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build:dist"
  },
  "keywords": [
    "beads",
    "issue-tracker",
    "project-management",
    "dolt",
    "web-ui"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanandrewhenderson/pearl.git"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@fastify/static": "^9.1.0",
    "execa": "^9.5.0",
    "fastify": "^5.2.0",
    "mysql2": "^3.12.0",
    "open": "^10.1.0",
    "picocolors": "^1.1.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@pearl/shared": "workspace:*",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
