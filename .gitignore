
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# compound-agent managed
.compound-agent/

# Nested .claude caches (matches root .claude/.gitignore pattern)
**/.claude/.cache/

# Build outputs
packages/*/dist/
packages/backend/frontend-dist/
*.tsbuildinfo

# Dependencies
node_modules/

# Playwright
test-results/
playwright-report/
blob-report/

# Proof screenshots (regenerated by e2e tests)
docs/proof/**/*.png
.beads/__replica__/
