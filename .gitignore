
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# compound-agent managed
.compound-agent/

# Nested .claude caches (matches root .claude/.gitignore pattern)
**/.claude/.cache/

# Build outputs
packages/*/dist/
packages/pearl-bdui/frontend-dist/
*.tsbuildinfo

# Environment (secrets)
.env
.env.local

# Dependencies
node_modules/

# Coverage
coverage/

# Playwright
test-results/
playwright-report/
blob-report/

# Proof screenshots (regenerated by e2e tests)
docs/proof/**/*.png
.beads/__replica__/

# Pearl attachment files (local storage mode)
.pearl/attachments/
