{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter pearl-bdui dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test:e2e": "playwright test",
    "test:e2e:read": "playwright test --project=chromium",
    "test:e2e:write": "playwright test --project=write-tests",
    "test:e2e:ui": "playwright test --ui",
    "lint:deps": "depcruise packages/*/src --config .dependency-cruiser.cjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@playwright/test": "^1.59.1",
    "compound-agent": "^2.7.2",
    "dependency-cruiser": "^17.3.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
